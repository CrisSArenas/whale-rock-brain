# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API key — used by Sonnet 4.6 across the pipeline.
ANTHROPIC_API_KEY=sk-ant-...


# =============================================================================
# OPTIONAL — paid feed (the dashboard works without it; the X column is skipped)
# =============================================================================

# X (Twitter) v2 API bearer token. Required to enable the X source.
# - Get one at: https://developer.x.com/en/portal/dashboard
# - Tier guidance:
#     Basic ($200/mo) — 10K tweets/mo, recent-search 7-day window. Sufficient
#     for ~10 tickers refreshed hourly.
#     Pro   ($5K/mo) — full archive, 1M tweets/mo. For back-testing.
# - Once the project is created, generate a Bearer Token under "Keys and tokens"
#   and paste it below.
X_BEARER_TOKEN=


# =============================================================================
# OPTIONAL — free, raises rate limits or polite headers
# =============================================================================

# GitHub personal access token. Raises GitHub rate limit from 60/h to 5000/h.
# Get one at: https://github.com/settings/tokens?type=beta — no scopes needed
# for read-only public data.
GITHUB_TOKEN=

# SEC EDGAR requires a contact email in their User-Agent header per fair-access
# policy. Use a real address you'd be willing to receive an email at.
EDGAR_CONTACT_EMAIL=research@example.com


# =============================================================================
# Model + behavior knobs (defaults are sensible; change only if needed)
# =============================================================================
MODEL=claude-sonnet-4-6
MAX_TOKENS=2000
TEMPERATURE=0.3

LOG_LEVEL=INFO
LOG_JSON=false
